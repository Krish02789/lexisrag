# ── Required ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/lexisrag

# ── Optional ──────────────────────────────────────────────────────────────────
# Google Gemini 2.5 Flash API key (omit for extractive QA fallback)
GEMINI_API_KEY=

# Port for the production server (default: 8080)
PORT=8080

# Set automatically in production — do not set manually
NODE_ENV=production
